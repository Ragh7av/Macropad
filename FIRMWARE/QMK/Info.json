{
    "keyboard_name": "Macropad",
    "url": "",
    "maintainer": "Raghav",
    "width": 3,
    "height": 3,
    "processor": "RP2040",
    "bootloader": "rp2040",
    "features": {
        "bootmagic": true,
        "encoder": true,
        "rgblight": true
    },
    "matrix_pins": {
        "direct": [
            ["GP0", "GP1", "GP2"],
            ["GP3", "GP4", "GP5"],
            ["GP6", "GP7", "GP8"]
        ]
    },
    "encoder": {
        "rotary": [
            {"pin_a": "GP26", "pin_b": "GP27", "resolution": 4}
        ]
    },
    "rgblight": {
        "led_count": 14,
        "pin": "GP29",
        "animations": {
            "breathing": true,
            "rainbow_mood": true,
            "rainbow_swirl": true,
            "knight": true
        }
    },
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 1], "x": 1, "y": 0},
                {"matrix": [0, 2], "x": 2, "y": 0},
                {"matrix": [1, 0], "x": 0, "y": 1},
                {"matrix": [1, 1], "x": 1, "y": 1},
                {"matrix": [1, 2], "x": 2, "y": 1},
                {"matrix": [2, 0], "x": 0, "y": 2},
                {"matrix": [2, 1], "x": 1, "y": 2},
                {"matrix": [2, 2], "x": 2, "y": 2}
            ]
        }
    }
}
